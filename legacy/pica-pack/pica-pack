#!/usr/bin/env bash
set -euo pipefail

PICA_VERSION_DEFAULT="0.1.27"
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

msg() {
  echo "==> $*"
}

msg2() {
  echo "  -> $*"
}

usage() {
  cat <<'EOF'
Usage:
  pica-pack build <staging_dir> [--outdir DIR]

staging_dir must contain:
  - manifest
  - cmd/
  - binary/ is optional
  - depend/ is optional
  - LICENSE is optional

If binary/ exists, the recommended layout is:
  binary/<platform>/<arch>/*.ipk

If depend/ exists, the recommended layout is:
  depend/<platform>/<arch>/*.ipk

When such layout is present, pica-pack will build one package per
<platform>/<arch> combination.

Package filename:
  <pkgname>-<pkgver>-<pkgrel>-<platform>-<arch>.pkg.tar.gz

Manifest format (Arch-like key/value lines):
  pkgname = demo
  pkgver = 1.0.0
  pkgrel = 1
  platform = all
  arch = all
  pica = 0.1.27
  (optional) pkgdesc/url/packager/size
  (repeatable) opkg/binary/cmd/depend
EOF
}

die() {
  echo "pica-pack: $*" >&2
  exit 1
}

manifest_get_first() {
  local manifest_file="$1"
  local key="$2"
  awk -F'=' -v k="$key" '
    $0 ~ /^[[:space:]]*#/ { next }
    NF < 2 { next }
    {
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", $1)
      if ($1 != k) next
      v = $2
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", v)
      print v
      exit
    }
  ' "$manifest_file"
}

manifest_delete_key() {
  local manifest_file="$1"
  local key="$2"
  awk -F'=' -v k="$key" '
    $0 ~ /^[[:space:]]*#/ { print; next }
    NF < 2 { print; next }
    {
      kk = $1
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", kk)
      if (kk == k) next
      print
    }
  ' "$manifest_file"
}

manifest_append_kv() {
  local manifest_file="$1"
  local key="$2"
  local value="$3"
  printf '%s = %s\n' "$key" "$value" >>"$manifest_file"
}

main_build() {
  local staging_dir="$1"
  shift

  local outdir=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --outdir)
        outdir="$2"
        shift 2
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        die "unknown arg: $1"
        ;;
    esac
  done

  [[ -d "$staging_dir" ]] || die "not a directory: $staging_dir"
  [[ -f "$staging_dir/manifest" ]] || die "missing manifest in $staging_dir"
  [[ -d "$staging_dir/cmd" ]] || die "missing cmd/ in $staging_dir"

  local manifest_file="$staging_dir/manifest"
  local pkgname pkgver pkgrel platform arch pica
  pkgname="$(manifest_get_first "$manifest_file" pkgname)"
  pkgver="$(manifest_get_first "$manifest_file" pkgver)"
  pkgrel="$(manifest_get_first "$manifest_file" pkgrel)"
  platform="$(manifest_get_first "$manifest_file" platform)"
  arch="$(manifest_get_first "$manifest_file" arch)"
  pica="$(manifest_get_first "$manifest_file" pica)"

  if [[ -z "$pkgrel" ]]; then
    # Backward compatibility with legacy pkgver=1.2.3-1.
    if [[ "$pkgver" == *"-"* ]]; then
      pkgrel="${pkgver#*-}"
      pkgver="${pkgver%%-*}"
    else
      pkgrel="1"
    fi
  fi

  platform="${platform:-all}"
  arch="${arch:-all}"

  [[ -n "$pkgname" ]] || die "manifest missing pkgname"
  [[ -n "$pkgver" ]] || die "manifest missing pkgver"
  [[ -n "$pkgrel" ]] || die "manifest missing pkgrel"
  # pica field is optional. If provided, treat it as minimum required pica-cli.
  if [[ -n "$pica" ]]; then
    msg2 "Pica requires >= $pica"
  else
    msg2 "Pica requires: (not specified)"
  fi

  if [[ -z "$outdir" ]]; then
    outdir="$SCRIPT_DIR/bin/$pkgname"
  fi
  mkdir -p "$outdir"

  local binary_dir="$staging_dir/binary"
  local depend_dir="$staging_dir/depend"
  local has_matrix=0
  if [[ -d "$binary_dir" ]]; then
    if find "$binary_dir" -mindepth 2 -maxdepth 2 -type d >/dev/null 2>&1; then
      has_matrix=1
    fi
  fi
  if [[ "$has_matrix" -eq 0 && -d "$depend_dir" ]]; then
    if find "$depend_dir" -mindepth 2 -maxdepth 2 -type d >/dev/null 2>&1; then
      has_matrix=1
    fi
  fi

  build_one() {
    local build_platform="$1"
    local build_arch="$2"

    local pkgfile
    if [[ "$build_platform" == "all" ]]; then
      pkgfile="${pkgname}-${pkgver}-${pkgrel}-${build_arch}.pkg.tar.gz"
    else
      pkgfile="${pkgname}-${pkgver}-${pkgrel}-${build_platform}-${build_arch}.pkg.tar.gz"
    fi

    (
      local tmpdir
      tmpdir="$(mktemp -d)"
      trap 'rm -rf "${tmpdir:-}"' EXIT

      msg "Making package: $pkgname ${pkgver}-${pkgrel}"
      msg2 "Platform: $build_platform"
      msg2 "Arch: $build_arch"
      if [[ -n "$pica" ]]; then
        msg2 "Pica requires >= $pica"
      else
        msg2 "Pica requires: (not specified)"
      fi
      msg2 "Creating archive..."

      # Compose final manifest for the build artifact.
      # Build output is allowed to diverge from source manifest.
      # - Inject builddate/size
      # - Override platform/arch
      # - Remove old compatibility fields (no fallback logic)
      # - Do not try to preserve /platform/arch paths in output
      cp "$staging_dir/manifest" "$tmpdir/manifest.src"
      manifest_delete_key "$tmpdir/manifest.src" builddate >"$tmpdir/manifest"
      mv "$tmpdir/manifest" "$tmpdir/manifest.tmp"
      manifest_delete_key "$tmpdir/manifest.tmp" size >"$tmpdir/manifest"
      mv "$tmpdir/manifest" "$tmpdir/manifest.tmp"
      manifest_delete_key "$tmpdir/manifest.tmp" platform >"$tmpdir/manifest"
      mv "$tmpdir/manifest" "$tmpdir/manifest.tmp"
      manifest_delete_key "$tmpdir/manifest.tmp" arch >"$tmpdir/manifest"
      mv "$tmpdir/manifest" "$tmpdir/manifest.tmp"
      manifest_delete_key "$tmpdir/manifest.tmp" pkgver >"$tmpdir/manifest"
      mv "$tmpdir/manifest" "$tmpdir/manifest.tmp"
      manifest_delete_key "$tmpdir/manifest.tmp" pkgrel >"$tmpdir/manifest"
      mv "$tmpdir/manifest" "$tmpdir/manifest.tmp"
      manifest_delete_key "$tmpdir/manifest.tmp" uname >"$tmpdir/manifest"
      rm -f "$tmpdir/manifest.tmp"
      rm -f "$tmpdir/manifest.src"

      manifest_append_kv "$tmpdir/manifest" builddate "$(date +%s)"
      manifest_append_kv "$tmpdir/manifest" pkgver "$pkgver"
      manifest_append_kv "$tmpdir/manifest" pkgrel "$pkgrel"
      manifest_append_kv "$tmpdir/manifest" platform "$build_platform"
      manifest_append_kv "$tmpdir/manifest" arch "$build_arch"

      if [[ -d "$staging_dir/cmd" ]]; then
        mkdir -p "$tmpdir/cmd"
        cp -a "$staging_dir/cmd/." "$tmpdir/cmd/"
      fi

      if [[ -d "$binary_dir" ]]; then
        if [[ "$has_matrix" -eq 1 ]]; then
          local src="$binary_dir/$build_platform/$build_arch"
          [[ -d "$src" ]] || die "missing binary/$build_platform/$build_arch"
          mkdir -p "$tmpdir/binary"
          cp -a "$src/." "$tmpdir/binary/"
        else
          mkdir -p "$tmpdir/binary"
          cp -a "$binary_dir/." "$tmpdir/binary/"
        fi
      fi

      if [[ -d "$depend_dir" ]]; then
        if [[ "$has_matrix" -eq 1 ]]; then
          local dep_src="$depend_dir/$build_platform/$build_arch"
          if [[ -d "$dep_src" ]]; then
            mkdir -p "$tmpdir/depend"
            cp -a "$dep_src/." "$tmpdir/depend/"
          fi
        else
          mkdir -p "$tmpdir/depend"
          cp -a "$depend_dir/." "$tmpdir/depend/"
        fi
      fi

    if [[ -f "$staging_dir/LICENSE" ]]; then
      cp "$staging_dir/LICENSE" "$tmpdir/LICENSE"
    fi

      # Estimate final archive size first, then write it into manifest.
      # (We create a temporary archive, measure bytes, then rebuild once.)
      local pkg_tmp
      pkg_tmp="$tmpdir/$pkgfile"

      # cmd/ is the only lifecycle/script payload directory.

      local tar_items=(manifest cmd)
      [[ -d "$tmpdir/binary" ]] && tar_items+=(binary)
      [[ -d "$tmpdir/depend" ]] && tar_items+=(depend)
      [[ -f "$tmpdir/LICENSE" ]] && tar_items+=(LICENSE)
      tar -C "$tmpdir" -czf "$pkg_tmp" "${tar_items[@]}"

      local pkg_size
      pkg_size="$(wc -c <"$pkg_tmp" | tr -d '[:space:]')"
      manifest_append_kv "$tmpdir/manifest" size "$pkg_size"

      tar -C "$tmpdir" -czf "$outdir/$pkgfile" "${tar_items[@]}"

      msg "Finished: $outdir/$pkgfile"
      echo "$outdir/$pkgfile"
    )
  }

  if [[ "$has_matrix" -eq 1 ]]; then
    local build_platform build_arch
    local roots=()
    [[ -d "$binary_dir" ]] && roots+=("$binary_dir")
    [[ -d "$depend_dir" ]] && roots+=("$depend_dir")
    [[ ${#roots[@]} -gt 0 ]] || die "matrix layout detected but neither binary/ nor depend/ exists"

    while IFS= read -r build_platform; do
      while IFS= read -r build_arch; do
        build_one "$build_platform" "$build_arch"
      done < <(
        for r in "${roots[@]}"; do
          [[ -d "$r/$build_platform" ]] || continue
          find "$r/$build_platform" -mindepth 1 -maxdepth 1 -type d -printf '%f\n'
        done | sort -u
      )
    done < <(
      for r in "${roots[@]}"; do
        find "$r" -mindepth 1 -maxdepth 1 -type d -printf '%f\n'
      done | sort -u
    )
  else
    build_one "$platform" "$arch"
  fi
}

main() {
  if [[ $# -lt 1 ]]; then
    usage
    exit 2
  fi

  local cmd="$1"
  shift

  case "$cmd" in
    build)
      [[ $# -ge 1 ]] || die "build requires <staging_dir>"
      main_build "$@"
      ;;
    -h|--help|help)
      usage
      ;;
    *)
      die "unknown command: $cmd"
      ;;
  esac
}

main "$@"
