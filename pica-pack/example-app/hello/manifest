# luci = lua1
# luci = js2

# If your package needs opkg deps, list them (optional):
depend = busybox

# If you bundle opkg ipks in binary/, list them here (optional):
# opkg = luci

# Optional: if you want pica -R to delete installed /usr/bin files safely,
# list them explicitly (relative paths under /usr/bin):
cmd = pica-sync
cmd = pica-update
cmd = pica-remove

cmd_install = cmd/install
cmd_update = cmd/update
cmd_remove = cmd/remove
