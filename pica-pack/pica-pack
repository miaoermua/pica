#!/usr/bin/env bash
set -euo pipefail

PICA_VERSION_DEFAULT="0.0.25"
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

msg() {
  echo "==> $*"
}

msg2() {
  echo "  -> $*"
}

usage() {
  cat <<'EOF'
Usage:
  pica-pack build <staging_dir> [--outdir DIR]

staging_dir must contain:
  - manifest
  - cmd/
  - binary/ is optional
  - LICENSE is optional

If binary/ exists, the recommended layout is:
  binary/<platform>/<arch>/*.ipk

When such layout is present, pica-pack will build one package per
<platform>/<arch> combination.

Package filename:
  <pkgname>-<pkgver>-<platform>-<arch>.pkg.tar.gz

Manifest format (Arch-like key/value lines):
  pkgname = demo
  pkgver = 1.0.0-1
  platform = all
  arch = all
  pica = 0.0.25
  (optional) pkgdesc/url/packager/size
  (repeatable) opkg/binary/cmd/depend
EOF
}

die() {
  echo "pica-pack: $*" >&2
  exit 1
}

manifest_get_first() {
  local manifest_file="$1"
  local key="$2"
  awk -F'=' -v k="$key" '
    $0 ~ /^[[:space:]]*#/ { next }
    NF < 2 { next }
    {
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", $1)
      if ($1 != k) next
      v = $2
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", v)
      print v
      exit
    }
  ' "$manifest_file"
}

main_build() {
  local staging_dir="$1"
  shift

  local outdir=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --outdir)
        outdir="$2"
        shift 2
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      *)
        die "unknown arg: $1"
        ;;
    esac
  done

  [[ -d "$staging_dir" ]] || die "not a directory: $staging_dir"
  [[ -f "$staging_dir/manifest" ]] || die "missing manifest in $staging_dir"
  [[ -d "$staging_dir/cmd" ]] || die "missing cmd/ in $staging_dir"

  local manifest_file="$staging_dir/manifest"
  local pkgname pkgver platform arch pica
  pkgname="$(manifest_get_first "$manifest_file" pkgname)"
  pkgver="$(manifest_get_first "$manifest_file" pkgver)"
  platform="$(manifest_get_first "$manifest_file" platform)"
  arch="$(manifest_get_first "$manifest_file" arch)"
  pica="$(manifest_get_first "$manifest_file" pica)"

  platform="${platform:-all}"
  arch="${arch:-all}"

  [[ -n "$pkgname" ]] || die "manifest missing pkgname"
  [[ -n "$pkgver" ]] || die "manifest missing pkgver"
  # pica field is optional. If provided, treat it as minimum required pica-cli.
  if [[ -n "$pica" ]]; then
    msg2 "Pica requires >= $pica"
  else
    msg2 "Pica requires: (not specified)"
  fi

  if [[ -z "$outdir" ]]; then
    outdir="$SCRIPT_DIR/bin/$pkgname"
  fi
  mkdir -p "$outdir"

  local binary_dir="$staging_dir/binary"
  local has_matrix=0
  if [[ -d "$binary_dir" ]]; then
    if find "$binary_dir" -mindepth 2 -maxdepth 2 -type d >/dev/null 2>&1; then
      has_matrix=1
    fi
  fi

  build_one() {
    local build_platform="$1"
    local build_arch="$2"

    local pkgfile
    if [[ "$build_platform" == "all" ]]; then
      pkgfile="${pkgname}-${pkgver}-${build_arch}.pkg.tar.gz"
    else
      pkgfile="${pkgname}-${pkgver}-${build_platform}-${build_arch}.pkg.tar.gz"
    fi

    (
      local tmpdir
      tmpdir="$(mktemp -d)"
      trap 'rm -rf "${tmpdir:-}"' EXIT

      msg "Making package: $pkgname $pkgver"
      msg2 "Platform: $build_platform"
      msg2 "Arch: $build_arch"
      if [[ -n "$pica" ]]; then
        msg2 "Pica requires >= $pica"
      else
        msg2 "Pica requires: (not specified)"
      fi
      msg2 "Creating archive..."

      # Compose final manifest for the build artifact.
      # Source manifest should not have to include builddate/size.
      cp "$staging_dir/manifest" "$tmpdir/manifest"
      {
        echo "builddate = $(date +%s)"
        echo "platform = $build_platform"
        echo "arch = $build_arch"
      } >>"$tmpdir/manifest"

      mkdir -p "$tmpdir/cmd"
      cp -a "$staging_dir/cmd/." "$tmpdir/cmd/"

      if [[ -d "$binary_dir" ]]; then
        if [[ "$has_matrix" -eq 1 ]]; then
          local src="$binary_dir/$build_platform/$build_arch"
          if [[ -d "$src" ]]; then
            mkdir -p "$tmpdir/binary/$build_platform/$build_arch"
            cp -a "$src/." "$tmpdir/binary/$build_platform/$build_arch/"
          fi
        else
          mkdir -p "$tmpdir/binary"
          cp -a "$binary_dir/." "$tmpdir/binary/"
        fi
      fi

    if [[ -f "$staging_dir/LICENSE" ]]; then
      cp "$staging_dir/LICENSE" "$tmpdir/LICENSE"
    fi

      # Estimate final archive size first, then write it into manifest.
      # (We create a temporary archive, measure bytes, then rebuild once.)
      local pkg_tmp
      pkg_tmp="$tmpdir/$pkgfile"

      if [[ -d "$tmpdir/binary" ]]; then
        if [[ -f "$tmpdir/LICENSE" ]]; then
          tar -C "$tmpdir" -czf "$pkg_tmp" manifest cmd binary LICENSE
        else
          tar -C "$tmpdir" -czf "$pkg_tmp" manifest cmd binary
        fi
      else
        if [[ -f "$tmpdir/LICENSE" ]]; then
          tar -C "$tmpdir" -czf "$pkg_tmp" manifest cmd LICENSE
        else
          tar -C "$tmpdir" -czf "$pkg_tmp" manifest cmd
        fi
      fi

      local pkg_size
      pkg_size="$(wc -c <"$pkg_tmp" | tr -d '[:space:]')"
      echo "size = $pkg_size" >>"$tmpdir/manifest"

      if [[ -d "$tmpdir/binary" ]]; then
        if [[ -f "$tmpdir/LICENSE" ]]; then
          tar -C "$tmpdir" -czf "$outdir/$pkgfile" manifest cmd binary LICENSE
        else
          tar -C "$tmpdir" -czf "$outdir/$pkgfile" manifest cmd binary
        fi
      else
        if [[ -f "$tmpdir/LICENSE" ]]; then
          tar -C "$tmpdir" -czf "$outdir/$pkgfile" manifest cmd LICENSE
        else
          tar -C "$tmpdir" -czf "$outdir/$pkgfile" manifest cmd
        fi
      fi

      msg "Finished: $outdir/$pkgfile"
      echo "$outdir/$pkgfile"
    )
  }

  if [[ "$has_matrix" -eq 1 ]]; then
    local build_platform build_arch
    while IFS= read -r build_platform; do
      while IFS= read -r build_arch; do
        build_one "$build_platform" "$build_arch"
      done < <(find "$binary_dir/$build_platform" -mindepth 1 -maxdepth 1 -type d -printf '%f\n' | sort)
    done < <(find "$binary_dir" -mindepth 1 -maxdepth 1 -type d -printf '%f\n' | sort)
  else
    build_one "$platform" "$arch"
  fi
}

main() {
  if [[ $# -lt 1 ]]; then
    usage
    exit 2
  fi

  local cmd="$1"
  shift

  case "$cmd" in
    build)
      [[ $# -ge 1 ]] || die "build requires <staging_dir>"
      main_build "$@"
      ;;
    -h|--help|help)
      usage
      ;;
    *)
      die "unknown command: $cmd"
      ;;
  esac
}

main "$@"
