#!/usr/bin/env bash
set -euo pipefail

PICA_VERSION="0.1.0"

PICA_ETC_DIR="${PICA_ETC_DIR:-/etc/pica}"
PICA_CONF_FILE="${PICA_CONF_FILE:-${PICA_ETC_DIR}/pica.json}"

PICA_STATE_DIR="${PICA_STATE_DIR:-/var/lib/pica}"
PICA_DB_FILE="${PICA_DB_FILE:-${PICA_STATE_DIR}/db.json}"
PICA_INDEX_FILE="${PICA_INDEX_FILE:-${PICA_STATE_DIR}/index.json}"
PICA_CACHE_DIR="${PICA_CACHE_DIR:-${PICA_STATE_DIR}/cache}"
PICA_REPOS_CACHE_DIR="${PICA_REPOS_CACHE_DIR:-${PICA_CACHE_DIR}/repos}"
PICA_REPORT_FILE="${PICA_REPORT_FILE:-${PICA_STATE_DIR}/install-report.json}"
PICA_LOCK_FILE="${PICA_LOCK_FILE:-${PICA_STATE_DIR}/db.lck}"
PICA_JSON_MODE="none"
PICA_JSON_LAST_PHASE=""
PICA_JSON_HAS_TEXT=0
PICA_LOCK_FD=""
PICA_LOCK_DIR=""
PICA_LOCK_HELD=0
PICA_NON_INTERACTIVE=0
PICA_FEED_POLICY="ask"
PICA_ERROR_CODE="E_RUNTIME"

set_error_code() {
  PICA_ERROR_CODE="$1"
}

json_set_phase() {
  PICA_JSON_LAST_PHASE="$1"
}

json_emit_error() {
  local message="$1"
  [[ "$PICA_JSON_MODE" == "none" ]] && return 0

  if ! command -v jq >/dev/null 2>&1; then
    return 0
  fi

  local phase
  phase="${PICA_JSON_LAST_PHASE:-unknown}"
  jq -n \
    --arg ok "false" \
    --arg code "${PICA_ERROR_CODE:-E_RUNTIME}" \
    --arg message "$message" \
    --arg phase "$phase" \
    '{ok:($ok=="true"), code:$code, message:$message, phase:$phase}'
}

json_emit_success() {
  local command="$1"
  local target="$2"
  [[ "$PICA_JSON_MODE" == "all" ]] || return 0
  [[ "$PICA_JSON_HAS_TEXT" -eq 0 ]] || return 0
  command -v jq >/dev/null 2>&1 || return 0

  jq -n \
    --arg ok "true" \
    --arg command "$command" \
    --arg target "$target" \
    '{ok:($ok=="true"), command:$command, target:$target}'
}

acquire_lock() {
  mkdir -p "$PICA_STATE_DIR"

  if command -v flock >/dev/null 2>&1; then
    exec {PICA_LOCK_FD}>"$PICA_LOCK_FILE" || die "cannot open lock file: $PICA_LOCK_FILE"
    if ! flock -n "$PICA_LOCK_FD"; then
      set_error_code E_LOCK_BUSY
      die "cannot lock pica database: $PICA_LOCK_FILE"
    fi
    PICA_LOCK_HELD=1
    return 0
  fi

  # Fallback when flock is unavailable.
  PICA_LOCK_DIR="${PICA_LOCK_FILE}.d"
  if ! mkdir "$PICA_LOCK_DIR" 2>/dev/null; then
    set_error_code E_LOCK_BUSY
    die "cannot lock pica database: ${PICA_LOCK_DIR} exists"
  fi
  printf '%s\n' "$$" >"$PICA_LOCK_DIR/pid" 2>/dev/null || true
  PICA_LOCK_HELD=1
}

release_lock() {
  [[ "$PICA_LOCK_HELD" -eq 1 ]] || return 0

  if [[ -n "${PICA_LOCK_FD:-}" ]]; then
    flock -u "$PICA_LOCK_FD" 2>/dev/null || true
    exec {PICA_LOCK_FD}>&- 2>/dev/null || true
    PICA_LOCK_FD=""
  fi

  if [[ -n "${PICA_LOCK_DIR:-}" ]]; then
    rm -rf "$PICA_LOCK_DIR" 2>/dev/null || true
    PICA_LOCK_DIR=""
  fi

  PICA_LOCK_HELD=0
}

log_info() {
  PICA_JSON_HAS_TEXT=1
  echo ":: $*"
}

log_warn() {
  PICA_JSON_HAS_TEXT=1
  echo "warning: $*" >&2
}

ver_ge() {
  # Returns 0 if $1 >= $2 (numeric dot-separated).
  # Examples: ver_ge 0.0.15 0.0.1 -> true
  local a="$1" b="$2"
  local IFS='.'
  local -a av bv
  read -r -a av <<<"$a"
  read -r -a bv <<<"$b"

  local i max
  max=${#av[@]}
  if [[ ${#bv[@]} -gt $max ]]; then
    max=${#bv[@]}
  fi
  for ((i=0; i<max; i++)); do
    local ai bi
    ai=${av[i]:-0}
    bi=${bv[i]:-0}
    [[ "$ai" =~ ^[0-9]+$ ]] || die "invalid version: $a"
    [[ "$bi" =~ ^[0-9]+$ ]] || die "invalid version: $b"
    if ((ai > bi)); then
      return 0
    fi
    if ((ai < bi)); then
      return 1
    fi
  done
  return 0
}

pkgver_ge() {
  # Compare pkgver like 1.2.3-1 (semver-release).
  # Returns 0 if $1 >= $2, best-effort.
  local a="$1" b="$2"
  if [[ -z "$b" ]]; then
    return 0
  fi
  if [[ -z "$a" ]]; then
    return 1
  fi

  local av ar bv br
  av="${a%%-*}"
  ar="${a#*-}"
  [[ "$ar" == "$a" ]] && ar="0"
  bv="${b%%-*}"
  br="${b#*-}"
  [[ "$br" == "$b" ]] && br="0"

  if [[ "$av" =~ ^[0-9]+(\.[0-9]+)*$ && "$bv" =~ ^[0-9]+(\.[0-9]+)*$ ]]; then
    if ver_ge "$av" "$bv"; then
      if ver_ge "$bv" "$av"; then
        [[ "$ar" =~ ^[0-9]+$ && "$br" =~ ^[0-9]+$ ]] || return 0
        (( ar >= br ))
        return $?
      fi
      return 0
    fi
    return 1
  fi

  # Fallback: lexicographic compare.
  [[ "$a" == "$b" ]] && return 0
  [[ "$a" > "$b" ]] && return 0 || return 1
}

pkgver_cmp_key() {
  local pkgver="$1"
  local pkgrel="$2"

  if [[ -n "$pkgrel" ]]; then
    echo "${pkgver}-${pkgrel}"
    return 0
  fi
  echo "$pkgver"
}

manifest_pkgver_cmp_key() {
  local manifest_json="$1"
  local pkgver pkgrel
  pkgver="$(manifest_get_first "$manifest_json" pkgver)"
  pkgrel="$(manifest_get_first "$manifest_json" pkgrel)"
  pkgver_cmp_key "$pkgver" "$pkgrel"
}

manifest_pkgver_display() {
  local manifest_json="$1"
  local pkgver pkgrel
  pkgver="$(manifest_get_first "$manifest_json" pkgver)"
  pkgrel="$(manifest_get_first "$manifest_json" pkgrel)"
  if [[ -n "$pkgrel" ]]; then
    echo "${pkgver}-${pkgrel}"
    return 0
  fi
  echo "$pkgver"
}

selector_is_structured() {
  local selector="$1"
  [[ "$selector" == *"@"* || "$selector" == *":"* || "$selector" == *"("* || "$selector" == *"）"* || "$selector" == *"（"* ]]
}

parse_app_selector() {
  # Supported selectors:
  #   app
  #   app@author
  #   app@author:version
  #   app@author:version(branch)
  # Full-width variants are normalized:
  #   app@作者：版本（分支）
  local selector="$1"

  local norm="$selector"
  norm="${norm//：/:}"
  norm="${norm//（/(}"
  norm="${norm//）/)}"

  local appname="$norm"
  local author=""
  local version=""
  local branch=""

  if [[ "$norm" =~ ^([^@]+)@([^:]+):(.*)$ ]]; then
    appname="${BASH_REMATCH[1]}"
    author="${BASH_REMATCH[2]}"
    local tail
    tail="${BASH_REMATCH[3]}"
    if [[ "$tail" =~ ^([^()]+)\(([^()]+)\)$ ]]; then
      version="${BASH_REMATCH[1]}"
      branch="${BASH_REMATCH[2]}"
    else
      version="$tail"
    fi
  elif [[ "$norm" =~ ^([^@]+)@([^()]+)\(([^()]+)\)$ ]]; then
    appname="${BASH_REMATCH[1]}"
    author="${BASH_REMATCH[2]}"
    branch="${BASH_REMATCH[3]}"
  elif [[ "$norm" =~ ^([^@]+)@([^:]+)$ ]]; then
    appname="${BASH_REMATCH[1]}"
    author="${BASH_REMATCH[2]}"
  elif [[ "$norm" =~ ^([^:]+):(.*)$ ]]; then
    appname="${BASH_REMATCH[1]}"
    local tail
    tail="${BASH_REMATCH[2]}"
    if [[ "$tail" =~ ^([^()]+)\(([^()]+)\)$ ]]; then
      version="${BASH_REMATCH[1]}"
      branch="${BASH_REMATCH[2]}"
    else
      version="$tail"
    fi
  fi

  jq -n \
    --arg raw "$selector" \
    --arg norm "$norm" \
    --arg appname "$appname" \
    --arg author "$author" \
    --arg version "$version" \
    --arg branch "$branch" \
    '{raw:$raw, norm:$norm, appname:$appname, author:$author, version:$version, branch:$branch}'
}

opkg_snapshot_installed() {
  local out_file="$1"
  opkg list-installed 2>/dev/null | awk -F' - ' '{print $1}' | sed '/^$/d' >"$out_file"
}

pkg_list_diff_added() {
  local before_file="$1"
  local after_file="$2"
  comm -13 <(sort -u "$before_file") <(sort -u "$after_file")
}

ipk_dir_has_pkg() {
  local dir="$1"
  local pkg="$2"

  [[ -d "$dir" ]] || return 1
  shopt -s nullglob
  local ipk
  for ipk in "$dir"/*.ipk; do
    local base
    base="$(basename "$ipk")"
    if [[ "$base" == "${pkg}_"* || "$base" == "${pkg}-"* ]]; then
      shopt -u nullglob
      return 0
    fi
  done
  shopt -u nullglob
  return 1
}

precheck_dep_source() {
  local dep="$1"
  local ipk_dir="$2"

  if opkg_is_installed "$dep"; then
    echo installed
    return 0
  fi
  if opkg_has_package "$dep"; then
    echo feed
    return 0
  fi
  if ipk_dir_has_pkg "$ipk_dir" "$dep"; then
    echo packaged
    return 0
  fi
  echo missing
}

build_precheck_report() {
  local manifest_json="$1"
  local depend_dir="$2"
  local binary_dir="$3"
  local app_list_input="$4"

  local tmp
  tmp="$(mktemp -d)"

  local kmod_file base_file app_file
  kmod_file="$tmp/kmod.list"
  base_file="$tmp/base.list"
  app_file="$tmp/app.list"

  manifest_get_array "$manifest_json" kmod >"$kmod_file" || true
  manifest_get_array "$manifest_json" base >"$base_file" || true
  printf '%s\n' "$app_list_input" | sed '/^$/d' >"$app_file"

  local result
  result="$(jq -n \
    --slurpfile kmod <(
      awk 'NF{print}' "$kmod_file" | while IFS= read -r dep; do
        status="$(precheck_dep_source "$dep" "")"
        jq -n --arg name "$dep" --arg status "$status" '{name:$name,status:$status}'
      done | jq -s .
    ) \
    --slurpfile base <(
      awk 'NF{print}' "$base_file" | while IFS= read -r dep; do
        status="$(precheck_dep_source "$dep" "$depend_dir")"
        jq -n --arg name "$dep" --arg status "$status" '{name:$name,status:$status}'
      done | jq -s .
    ) \
    --slurpfile app <(
      awk 'NF{print}' "$app_file" | while IFS= read -r dep; do
        status="$(precheck_dep_source "$dep" "$binary_dir")"
        jq -n --arg name "$dep" --arg status "$status" '{name:$name,status:$status}'
      done | jq -s .
    ) \
    '{kmod:($kmod[0] // []), base:($base[0] // []), app:($app[0] // [])}')"

  rm -rf "$tmp"
  echo "$result"
}

precheck_assert_no_missing() {
  local precheck_json="$1"
  local missing
  missing="$(jq -r '
    [
      (.kmod[]? | select(.status=="missing") | "kmod:" + .name),
      (.base[]? | select(.status=="missing") | "base:" + .name),
      (.app[]? | select(.status=="missing") | "app:" + .name)
    ]
    | .[]
  ' <<<"$precheck_json")"

  if [[ -n "$missing" ]]; then
    die "dependency precheck failed, missing: $(tr '\n' ' ' <<<"$missing" | sed -e 's/[[:space:]]\+/ /g' -e 's/[[:space:]]$//')"
  fi
}

report_set_install_result() {
  local pkgname="$1"
  local selector="$2"
  local manifest_json="$3"
  local precheck_json="$4"
  local tx_added_json="$5"
  local app_added_json="$6"

  local now
  now="$(date +%s)"

  if [[ ! -f "$PICA_REPORT_FILE" ]]; then
    cat >"$PICA_REPORT_FILE" <<'JSON'
{
  "schema": 1,
  "reports": {}
}
JSON
  fi

  jq --arg pkgname "$pkgname" \
     --arg selector "$selector" \
     --arg now "$now" \
     --argjson manifest "$manifest_json" \
     --argjson precheck "$precheck_json" \
     --argjson tx_added "$tx_added_json" \
     --argjson app_added "$app_added_json" '
    .reports[$pkgname] = {
      updated_at: ($now|tonumber),
      selector: $selector,
      package: {
        pkgname: ($manifest.pkgname // ""),
        appname: ($manifest.appname // $manifest.pkgname // ""),
        author: ($manifest.author // ""),
        version: ($manifest.version // ""),
        branch: ($manifest.branch // ""),
        protocol: ($manifest.protocol // ""),
        pkgver: ($manifest.pkgver // ""),
        pkgrel: ($manifest.pkgrel // "")
      },
      precheck: $precheck,
      dependency_diff: {
        transaction_added: $tx_added,
        app_stage_added: $app_added
      }
    }
  ' "$PICA_REPORT_FILE" >"$PICA_REPORT_FILE.tmp"
  mv "$PICA_REPORT_FILE.tmp" "$PICA_REPORT_FILE"
}

usage() {
  cat <<'EOF'
Usage:
  pica -S                 Sync (download repo.json and update index)
  pica -Su                Upgrade all installed pica packages
  pica -Syu               Sync, then upgrade all installed pica packages
  pica -Si <selector>     Install by selector (auto: opkg if available, else pica)
  pica -So <selector>     Install by selector (force opkg)
  pica -Sp <selector>     Install by selector (force pica repo)
  pica -U <pkgfile|url>   Install/Update from local file or URL
  pica -R <pkgname>       Remove package (no dependency handling)
  pica -Q                 List installed pica packages
  pica -Qi <pkgname>      Show installed package info
  pica -Ql <pkgname>      Show installed package license
  pica --json ...         Emit JSON on success and error (explicit only)
  pica --json-errors ...  Emit JSON only on error
  pica --non-interactive ...
                          Disable prompts (for backend/automation)
  pica --feed-policy <mode>
                          ask|feed-first|packaged-first|feed-only|packaged-only
  pica --version

Notes:
  - Requires: opkg, jq, tar
  - Config: /etc/pica/pica.json
  - State:  /var/lib/pica/db.json, /var/lib/pica/index.json
  - Lock:   /var/lib/pica/db.lck
  - Selector example: app@author:version(branch)
EOF
}

is_supported_pkg_url() {
  local value="$1"
  [[ "$value" == http://* || "$value" == https://* || "$value" == file://* ]]
}

sanitize_cache_filename() {
  local value="$1"
  value="$(sed 's/[^A-Za-z0-9._+-]/_/g' <<<"$value")"
  [[ -n "$value" ]] || value="remote-$(date +%s)-$$"
  if [[ "$value" != *.pkg.tar.gz ]]; then
    value+=".pkg.tar.gz"
  fi
  echo "$value"
}

die() {
  local msg="$*"

  if grep -qi 'No space left on device' <<<"$msg"; then
    set_error_code E_NO_SPACE
  fi

  json_emit_error "$*" >&2 || true
  echo "pica: $*" >&2
  exit 1
}

need_cmd() {
  if ! command -v "$1" >/dev/null 2>&1; then
    set_error_code E_MISSING_COMMAND
    die "missing required command: $1"
  fi
}

need_any_cmd() {
  local ok=1
  local name
  for name in "$@"; do
    if command -v "$name" >/dev/null 2>&1; then
      ok=0
      break
    fi
  done
  if [[ "$ok" -ne 0 ]]; then
    set_error_code E_MISSING_COMMAND
    die "missing required command (need one of: $*)"
  fi
}

format_df_compact() {
  df -k /overlay / 2>/dev/null | awk 'NR==1 || NR==2 || NR==3 {print}' | tr '\n' '; ' | sed 's/; $//'
}

opkg_install_pkg() {
  local label="$1"
  local target="$2"

  local before_df
  before_df="$(format_df_compact || true)"
  local out rc
  out="$(opkg install "$target" 2>&1)" && rc=0 || rc=$?
  if [[ "$rc" -ne 0 ]]; then
    local after_df
    after_df="$(format_df_compact || true)"
    if grep -qi 'No space left on device' <<<"$out"; then
      set_error_code E_NO_SPACE
      die "$label install failed: $target (storage-full). df_before=[$before_df] df_after=[$after_df] detail=[$out]"
    fi
    set_error_code E_OPKG_INSTALL
    die "$label install failed: $target detail=[$out]"
  fi
}

prompt_yn() {
  # Usage: prompt_yn "question" default_yes
  # - default_yes: 1 => [Y/n], 0 => [y/N]
  local question="$1"
  local default_yes="${2:-1}"
  local hint
  if [[ "$default_yes" -eq 1 ]]; then
    hint="[Y/n]"
  else
    hint="[y/N]"
  fi

  while true; do
    if [[ "$PICA_NON_INTERACTIVE" -eq 1 ]]; then
      [[ "$default_yes" -eq 1 ]] && return 0 || return 1
    fi
    printf "%s %s " "$question" "$hint" >&2
    local ans
    IFS= read -r ans || return 1
    ans="${ans,,}"
    case "$ans" in
      "")
        [[ "$default_yes" -eq 1 ]] && return 0 || return 1
        ;;
      y|yes)
        return 0
        ;;
      n|no)
        return 1
        ;;
      *)
        echo "Please answer y/yes or n/no." >&2
        ;;
    esac
  done
}

ensure_dirs() {
  mkdir -p "$PICA_ETC_DIR" "$PICA_STATE_DIR" "$PICA_CACHE_DIR" "$PICA_REPOS_CACHE_DIR"
  if [[ ! -f "$PICA_CONF_FILE" ]]; then
    cat >"$PICA_CONF_FILE" <<'JSON'
{
  "repos": [],
  "i18n": "zh-cn"
}
JSON
  fi

  if [[ ! -f "$PICA_DB_FILE" ]]; then
    cat >"$PICA_DB_FILE" <<'JSON'
{
  "schema": 1,
  "installed": {}
}
JSON
  fi

  if [[ ! -f "$PICA_INDEX_FILE" ]]; then
    cat >"$PICA_INDEX_FILE" <<'JSON'
{
  "schema": 1,
  "repos": {}
}
JSON
  fi
}

conf_get_i18n() {
  # Default i18n language for luci-i18n-*-<lang> packages.
  # This does NOT affect pica output language.
  if [[ -f "$PICA_CONF_FILE" ]]; then
    jq -r '.i18n // "zh-cn"' "$PICA_CONF_FILE" 2>/dev/null || echo "zh-cn"
  else
    echo "zh-cn"
  fi
}

db_get_installed_manifest() {
  local pkgname="$1"
  jq -c --arg pkgname "$pkgname" '.installed[$pkgname].manifest // empty' "$PICA_DB_FILE" 2>/dev/null || true
}

db_find_installed_pkgname_by_selector() {
  local selector="$1"
  local parsed appname author version branch
  parsed="$(parse_app_selector "$selector")"
  appname="$(jq -r '.appname' <<<"$parsed")"
  author="$(jq -r '.author' <<<"$parsed")"
  version="$(jq -r '.version' <<<"$parsed")"
  branch="$(jq -r '.branch' <<<"$parsed")"

  jq -r --arg appname "$appname" --arg author "$author" --arg version "$version" --arg branch "$branch" '
    .installed
    | to_entries
    | map(
        select(
          (.key == $appname) or
          ((.value.manifest.appname // "") == $appname) or
          ((.value.manifest.pkgname // "") == $appname)
        )
        | select($author == "" or (.value.manifest.author // "") == $author)
        | select(
            $version == "" or
            (.value.manifest.version // "") == $version or
            (.value.manifest.branch // "") == $version or
            (.value.manifest.pkgver // "") == $version or
            ((.value.manifest.pkgver // "") + "-" + ((.value.manifest.pkgrel // "") | if length > 0 then . else "0" end)) == $version
          )
        | select($branch == "" or (.value.manifest.branch // "") == $branch)
      )
    | .[0].key // ""
  ' "$PICA_DB_FILE" 2>/dev/null || true
}

detect_platform() {
  # Prefer OpenWrt release info; fall back to uname.
  if [[ -f /etc/openwrt_release ]]; then
    # shellcheck disable=SC1091
    . /etc/openwrt_release 2>/dev/null || true
    if [[ -n "${DISTRIB_TARGET:-}" ]]; then
      echo "$DISTRIB_TARGET"
      return 0
    fi
  fi
  uname -m
}

normalize_uname() {
  # Map common uname -m values to pica short names.
  # - x86_64 -> amd64
  # - aarch64 -> arm64
  local value="$1"
  case "$value" in
    x86_64) echo amd64 ;;
    aarch64) echo arm64 ;;
    *) echo "$value" ;;
  esac
}

compose_expected_pkg_filename() {
  local pkgname="$1"
  local pkgver="$2"
  local pkgrel="$3"
  local platform="$4"
  local arch="$5"

  if [[ "$platform" == "all" ]]; then
    echo "${pkgname}-${pkgver}-${pkgrel}-${arch}.pkg.tar.gz"
    return 0
  fi
  echo "${pkgname}-${pkgver}-${pkgrel}-${platform}-${arch}.pkg.tar.gz"
}

validate_repo_json_file() {
  local repo_json_file="$1"
  local repo_name="$2"

  local errors
  errors="$({
    jq -r '
      def nonempty_string: (type == "string") and (length > 0);
      def has_required_fields:
        (.pkgname | nonempty_string)
        and (.pkgver | nonempty_string)
        and (.pkgrel | nonempty_string)
        and (.platform | nonempty_string)
        and (.arch | nonempty_string)
        and (.filename | nonempty_string);
      def filename_safe:
        (.filename | type == "string")
        and (.filename | test("^[^/]+\\.pkg\\.tar\\.gz$"))
        and ((.filename | contains("..")) | not);
      def download_url_valid:
        (.download_url | type == "string")
        and ((.download_url | startswith("http://")) or (.download_url | startswith("https://")) or (.download_url | startswith("file://")));
      def expected_filename:
        if .platform == "all" then
          (.pkgname + "-" + .pkgver + "-" + .pkgrel + "-" + .arch + ".pkg.tar.gz")
        else
          (.pkgname + "-" + .pkgver + "-" + .pkgrel + "-" + .platform + "-" + .arch + ".pkg.tar.gz")
        end;

      if (.schema // null) != 1 then
        "schema must be 1"
      else
        empty
      end,
      if ((.packages // null) | type) != "array" then
        "packages must be array"
      else
        empty
      end,
      (.packages[]? as $pkg
        | if ($pkg | has_required_fields) then
            empty
          else
            "package entry missing required string fields: pkgname/pkgver/pkgrel/platform/arch/filename"
          end,
          if ($pkg | has_required_fields) and (($pkg | filename_safe) | not) then
            "package " + ($pkg.pkgname // "<unknown>") + ": invalid filename " + ($pkg.filename // "")
          else
            empty
          end,
          if ($pkg | has_required_fields) and ($pkg | filename_safe) and (($pkg.filename) != ($pkg | expected_filename)) then
            "package " + ($pkg.pkgname // "<unknown>") + ": filename mismatch, expected " + ($pkg | expected_filename) + ", got " + ($pkg.filename // "")
          else
            empty
          end,
          if ($pkg.download_url // null) != null and (($pkg | download_url_valid) | not) then
            "package " + ($pkg.pkgname // "<unknown>") + ": invalid download_url " + (($pkg.download_url // "")|tostring)
          else
            empty
          end
      )
    ' "$repo_json_file" 2>/dev/null || echo "repo.json validation parser error"
  } | sed '/^$/d')"

  if [[ -n "$errors" ]]; then
    log_warn "$repo_name: repo.json strict validation failed"
    while IFS= read -r line; do
      [[ -z "$line" ]] && continue
      log_warn "  - $line"
    done <<<"$errors"
    return 1
  fi
  return 0
}

detect_opkg_arches() {
  # OpenWrt architecture list as understood by opkg.
  # Example lines:
  #   arch all 1
  #   arch aarch64_cortex-a53 10
  opkg print-architecture 2>/dev/null | awk '{print $2}'
}

detect_luci_variant() {
  # Best-effort detection.
  # - OpenWrt classic LuCI uses Lua.
  # - luci2 is JS-based.
  if command -v uhttpd >/dev/null 2>&1; then
    :
  fi

  if opkg status luci 2>/dev/null | grep -qi '^Status: .*installed'; then
    echo lua1
    return 0
  fi
  if opkg status luci2 2>/dev/null | grep -qi '^Status: .*installed'; then
    echo js2
    return 0
  fi
  # Alternative package names exist; keep it conservative.
  echo unknown
}

manifest_has_type() {
  local manifest_json="$1"
  local t="$2"
  manifest_get_array "$manifest_json" type 2>/dev/null | awk -v t="$t" '$0==t{found=1} END{exit found?0:1}'
}

fetch_url() {
  local url="$1"
  if [[ "$url" == file://* ]]; then
    cat "${url#file://}"
    return $?
  fi
  if command -v uclient-fetch >/dev/null 2>&1; then
    uclient-fetch -O - "$url"
    return $?
  fi
  if command -v wget >/dev/null 2>&1; then
    wget -qO- "$url"
    return $?
  fi
  if command -v curl >/dev/null 2>&1; then
    curl -fsSL "$url"
    return $?
  fi
  die "no fetch tool found (need uclient-fetch, wget, or curl)"
}

opkg_has_package() {
  local name="$1"
  local out
  out="$(opkg info "$name" 2>/dev/null || true)"
  [[ -n "$out" ]] || return 1
  if grep -qi 'unknown package' <<<"$out"; then
    return 1
  fi
  return 0
}

opkg_is_installed() {
  local name="$1"
  opkg status "$name" 2>/dev/null | grep -qi '^Status: .*installed'
}

opkg_installed_version() {
  local name="$1"
  opkg status "$name" 2>/dev/null | awk -F': ' 'tolower($1)=="version" {print $2; exit}'
}

db_set_installed() {
  local pkgname="$1"
  local manifest_json="$2"
  local pkgfile="$3"
  local now
  now="$(date +%s)"

  jq --arg pkgname "$pkgname" \
     --arg pkgfile "$pkgfile" \
     --arg now "$now" \
     --argjson manifest "$manifest_json" \
     '.installed[$pkgname] = {manifest: $manifest, pkgfile: $pkgfile, installed_at: ($now|tonumber)}' \
     "$PICA_DB_FILE" >"$PICA_DB_FILE.tmp"
  mv "$PICA_DB_FILE.tmp" "$PICA_DB_FILE"
}

db_del_installed() {
  local pkgname="$1"
  jq --arg pkgname "$pkgname" 'del(.installed[$pkgname])' "$PICA_DB_FILE" >"$PICA_DB_FILE.tmp"
  mv "$PICA_DB_FILE.tmp" "$PICA_DB_FILE"
}

manifest_to_json() {
  # Convert key = value lines (Arch-like) into JSON. Repeated keys become arrays.
  local manifest_file="$1"
  jq -Rn --slurpfile lines <(sed -e 's/\r$//' "$manifest_file") '
    def trim: gsub("^\\s+|\\s+$"; "");
    def parse_line($l):
      ($l | sub("#.*$"; "") | trim) as $x
      | if ($x|length)==0 then empty else $x end
      | (capture("^(?<k>[^=]+)=(?<v>.*)$")?)
      | if . == null then empty else {k:(.k|trim), v:(.v|trim)} end;

    reduce ($lines[0][] | parse_line(.)) as $kv
      ({};
        if has($kv.k) then
          .[$kv.k] = (
            if (.[$kv.k] | type) == "array" then .[$kv.k] + [$kv.v]
            else [.[ $kv.k ], $kv.v]
            end
          )
        else
          .[$kv.k] = $kv.v
        end
      )
  '
}

manifest_get_first() {
  local manifest_json="$1"
  local key="$2"
  jq -r --arg k "$key" '
    .[$k] as $v |
    if $v == null then ""
    elif ($v|type)=="array" then ($v[0] // "")
    else ($v|tostring)
    end
  ' <<<"$manifest_json"
}

manifest_get_array() {
  local manifest_json="$1"
  local key="$2"
  jq -r --arg k "$key" '
    .[$k] as $v |
    if $v == null then empty
    elif ($v|type)=="array" then .[$k][]
    else (.[$k]|tostring)
    end
  ' <<<"$manifest_json"
}

manifest_get_scalar() {
  local manifest_json="$1"
  local key="$2"
  jq -r --arg k "$key" '
    .[$k] as $v |
    if $v == null then ""
    elif ($v|type)=="array" then ""
    else ($v|tostring)
    end
  ' <<<"$manifest_json"
}

manifest_to_selector() {
  local manifest_json="$1"
  local fallback_pkgname="${2:-}"
  local appname author version branch

  appname="$(manifest_get_first "$manifest_json" appname)"
  if [[ -z "$appname" ]]; then
    appname="$(manifest_get_first "$manifest_json" pkgname)"
  fi
  if [[ -z "$appname" ]]; then
    appname="$fallback_pkgname"
  fi
  author="$(manifest_get_first "$manifest_json" author)"
  version="$(manifest_get_first "$manifest_json" version)"
  branch="$(manifest_get_first "$manifest_json" branch)"

  local out="$appname"
  if [[ -n "$author" ]]; then
    out+="@$author"
  fi
  if [[ -n "$version" ]]; then
    out+=":$version"
  fi
  if [[ -n "$branch" ]]; then
    out+="($branch)"
  fi
  echo "$out"
}

run_hook() {
  local tmpdir="$1"
  local hook_rel="$2"
  local label="$3"

  [[ -n "$hook_rel" ]] || return 0

  local hook_path
  hook_path="$tmpdir/$hook_rel"
  [[ -f "$hook_path" ]] || die "$label hook not found: $hook_rel"

  log_info "Running $label hook: $hook_rel"
  bash "$hook_path"
}

run_cmd_install_tree() {
  local cmd_rel="$1"
  local label="$2"

  if [[ -z "$cmd_rel" ]]; then
    return 0
  fi

  if [[ "$cmd_rel" == /* ]]; then
    if [[ -f "$cmd_rel" ]]; then
      log_info "Running $label cmd: $cmd_rel"
      bash "$cmd_rel"
      return 0
    fi
    die "$label cmd not found: $cmd_rel"
  fi

  local cmd_path
  cmd_path="/usr/lib/pica/cmd/$cmd_rel"
  [[ -f "$cmd_path" ]] || die "$label cmd not found: $cmd_rel (expected at $cmd_path)"
  log_info "Running $label cmd: $cmd_rel"
  bash "$cmd_path"
}

sync_repos() {
  ensure_dirs
  log_info "Synchronizing package databases..."

  local repo_count
  repo_count="$(jq -r '.repos | length' "$PICA_CONF_FILE" 2>/dev/null || echo 0)"
  if [[ "$repo_count" == "0" ]]; then
    die "no repos configured in $PICA_CONF_FILE"
  fi

  local now platform
  now="$(date +%s)"
  platform="$(detect_platform)"

  local i
  for ((i=0; i<repo_count; i++)); do
    local name url repo_platform repo_json_file tmp
    name="$(jq -r --argjson i "$i" '.repos[$i].name // empty' "$PICA_CONF_FILE")"
    url="$(jq -r --argjson i "$i" '.repos[$i].url // empty' "$PICA_CONF_FILE")"
    repo_platform="$(jq -r --argjson i "$i" '.repos[$i].platform // empty' "$PICA_CONF_FILE")"

    [[ -n "$name" ]] || die "repo[$i] missing name"
    [[ -n "$url" ]] || die "repo[$i] missing url"

    repo_json_file="$PICA_REPOS_CACHE_DIR/$name.json"
    tmp="$repo_json_file.tmp"

    log_info "$name downloading..."
    if ! fetch_url "${url%/}/repo.json" >"$tmp"; then
      rm -f "$tmp" || true
      die "$name: failed to download repo.json"
    fi
    if ! jq -e . >/dev/null 2>&1 <"$tmp"; then
      rm -f "$tmp" || true
      die "$name: invalid repo.json"
    fi
    if ! validate_repo_json_file "$tmp" "$name"; then
      rm -f "$tmp" || true
      die "$name: repo.json failed strict schema/filename validation"
    fi
    mv "$tmp" "$repo_json_file"

    jq --arg name "$name" \
       --arg url "$url" \
       --arg platform "$platform" \
       --arg repo_platform "$repo_platform" \
       --arg now "$now" \
       --slurpfile repo "$repo_json_file" '
      .repos[$name] = {
        name: $name,
        url: $url,
        updated_at: ($now|tonumber),
        platform: (if ($repo_platform|length)>0 then $repo_platform else $platform end),
        data: $repo[0]
      }
    ' "$PICA_INDEX_FILE" >"$PICA_INDEX_FILE.tmp"
    mv "$PICA_INDEX_FILE.tmp" "$PICA_INDEX_FILE"

    log_info "$name updated"
  done

  # Optional checks (OpenWrt only): verify declared deps are available in opkg feeds.
  if command -v opkg >/dev/null 2>&1; then
    opkg update >/dev/null 2>&1 || true
    local missing_any=0
    while IFS= read -r dep; do
      [[ -z "$dep" ]] && continue
      if ! opkg_has_package "$dep"; then
        log_warn "opkg feed missing dependency: $dep"
        missing_any=1
      fi
    done < <(
      jq -r '
        .repos
        | to_entries
        | .[]
        | .value.data.packages[]?
        | (.manifest.base? // empty | if type=="array" then .[] else . end),
          (.manifest.kmod? // empty | if type=="array" then .[] else . end),
          (.manifest.app? // empty | if type=="array" then .[] else . end)
      ' "$PICA_INDEX_FILE" 2>/dev/null || true
    )
    if [[ "$missing_any" -ne 0 ]]; then
      log_warn "Some declared dependencies are missing in opkg feeds"
    fi
  fi
}

find_pica_package_in_index() {
  local selector="$1"
  ensure_dirs

  [[ -f "$PICA_INDEX_FILE" ]] || die "missing index: run 'pica -S' first"

  local host_platform
  host_platform="$(detect_platform)"

  local parsed appname author version branch
  parsed="$(parse_app_selector "$selector")"
  appname="$(jq -r '.appname' <<<"$parsed")"
  author="$(jq -r '.author' <<<"$parsed")"
  version="$(jq -r '.version' <<<"$parsed")"
  branch="$(jq -r '.branch' <<<"$parsed")"

  # Output:
  # cmpver\tpkgver\tpkgrel\trepo\turl\tfilename\tdownload_url\tpica\tpkgname
  jq -r --arg appname "$appname" --arg author "$author" --arg version "$version" --arg branch "$branch" '
    .repos
    | to_entries
    | map({repo: .key, url: .value.url, repo_platform: (.value.platform // ""), pkgs: (.value.data.packages // [])})
    | .[]
    | .pkgs[]
    | select((.appname // .pkgname // "") == $appname)
    | select($author == "" or (.author // "") == $author)
    | select(
        $version == "" or
        (.version // "") == $version or
        (.branch // "") == $version or
        (.pkgver // "") == $version or
        ((.pkgver // "") + "-" + ((.pkgrel // "") | if length > 0 then . else "0" end)) == $version
      )
    | select($branch == "" or (.branch // "") == $branch)
    | select((.platform // "all") == "all" or (.platform // "") == "'"$host_platform"'" or (.platform // "") == (.repo_platform // ""))
    | [
        ((.pkgver // "") + "-" + ((.pkgrel // "") | if length>0 then . else "0" end)),
        (.pkgver // ""),
        (.pkgrel // ""),
        .repo,
        .url,
        (.filename // ""),
        (.download_url // ""),
        (.pica // ""),
        (.pkgname // "")
      ]
      | @tsv
  ' "$PICA_INDEX_FILE"
}

install_pica_from_repo() {
  local selector="$1"
  ensure_dirs
  need_cmd tar

  local candidates best
  candidates="$(find_pica_package_in_index "$selector" || true)"
  [[ -n "$candidates" ]] || die "package not found in pica repos: $selector"

  # Choose best pkgver+pkgrel without relying on GNU sort -V (busybox compatibility).
  local line
  local best_ver=""
  best=""
  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    local v
    v="${line%%$'\t'*}"
    if pkgver_ge "$v" "$best_ver"; then
      best_ver="$v"
      best="$line"
    fi
  done <<<"$candidates"
  [[ -n "$best" ]] || die "package not found in pica repos: $selector"
  local cmpver pkgver pkgrel repo url filename download_url min_pica pkgname
  cmpver="$(cut -f1 <<<"$best")"
  pkgver="$(cut -f2 <<<"$best")"
  pkgrel="$(cut -f3 <<<"$best")"
  repo="$(cut -f4 <<<"$best")"
  url="$(cut -f5 <<<"$best")"
  filename="$(cut -f6 <<<"$best")"
  download_url="$(cut -f7 <<<"$best")"
  min_pica="$(cut -f8 <<<"$best")"
  pkgname="$(cut -f9 <<<"$best")"

  [[ -n "$filename" ]] || die "$repo: repo entry missing filename for $pkgname"
  [[ "$filename" != */* ]] || die "$repo: invalid filename (must not contain '/'): $filename"
  [[ "$filename" == *.pkg.tar.gz ]] || die "$repo: invalid filename (must end with .pkg.tar.gz): $filename"
  if [[ -n "$download_url" ]]; then
    is_supported_pkg_url "$download_url" || die "$repo: invalid download_url for $pkgname: $download_url"
  fi

  if [[ -n "$min_pica" ]]; then
    if ! ver_ge "$PICA_VERSION" "$min_pica"; then
      die "pica too old: pkg requires >= $min_pica, cli is $PICA_VERSION"
    fi
  fi

  mkdir -p "$PICA_CACHE_DIR/pkgs"

  local pkg_url cached
  pkg_url="$download_url"
  if [[ -z "$pkg_url" ]]; then
    pkg_url="${url%/}/packages/$filename"
  fi
  cached="$PICA_CACHE_DIR/pkgs/$filename"

  log_info "Downloading $pkgname ($cmpver) from $repo..."
  fetch_url "$pkg_url" >"$cached.tmp" || die "download failed: $pkg_url"
  mv "$cached.tmp" "$cached"
  install_pkgfile "$cached" "$selector"
}

install_app_via_opkg() {
  local selector="$1"
  local parsed app
  parsed="$(parse_app_selector "$selector")"
  app="$(jq -r '.appname' <<<"$parsed")"
  local selector_author selector_version selector_branch
  selector_author="$(jq -r '.author' <<<"$parsed")"
  selector_version="$(jq -r '.version' <<<"$parsed")"
  selector_branch="$(jq -r '.branch' <<<"$parsed")"
  ensure_dirs
  need_cmd opkg

  opkg update >/dev/null 2>&1 || true

  local lang
  lang="${PICA_LANG:-$(conf_get_i18n)}"

  local -a candidates
  candidates=("$app" "luci-app-$app" "luci-i18n-${app}-${lang}")

  local -a to_install
  local pkg
  for pkg in "${candidates[@]}"; do
    if opkg_has_package "$pkg"; then
      to_install+=("$pkg")
    fi
  done

  if [[ ${#to_install[@]} -eq 0 ]]; then
    die "opkg: package not found: $app"
  fi

  log_info "Installing (opkg): ${to_install[*]}"
  local p
  for p in "${to_install[@]}"; do
    opkg_install_pkg "opkg" "$p"
  done

  local base_ver
  base_ver="$(opkg_installed_version "$app" || true)"
  if [[ -z "$base_ver" ]]; then
    base_ver="$(opkg_installed_version "${to_install[0]}" || true)"
  fi

  local manifest_json
  manifest_json="$(
    jq -n \
      --arg pkgname "$app" \
      --arg appname "$app" \
      --arg author "$selector_author" \
      --arg version "$selector_version" \
      --arg branch "$selector_branch" \
      --arg pkgver "${base_ver:-}" \
      --arg platform "$(detect_platform)" \
      --arg arch "all" \
      --arg source "opkg" \
      --argjson opkgs "$(printf '%s\n' "${to_install[@]}" | jq -R . | jq -s .)" \
      '{pkgname:$pkgname, appname:$appname, author:$author, version:$version, branch:$branch, pkgver:$pkgver, platform:$platform, arch:$arch, source:$source, opkg:$opkgs}'
  )"

  db_set_installed "$app" "$manifest_json" "opkg"
  log_info "Transaction completed"
}

install_app_auto() {
  local selector="$1"
  local parsed app
  parsed="$(parse_app_selector "$selector")"
  app="$(jq -r '.appname' <<<"$parsed")"
  ensure_dirs
  need_cmd opkg

  # Update path: do not prompt. Keep the original install source.
  local installed_pkgname installed_manifest source
  installed_pkgname="$(db_find_installed_pkgname_by_selector "$selector")"
  installed_manifest=""
  if [[ -n "$installed_pkgname" ]]; then
    installed_manifest="$(db_get_installed_manifest "$installed_pkgname")"
  fi
  if [[ -n "$installed_manifest" ]]; then
    source="$(manifest_get_first "$installed_manifest" source)"
    case "$source" in
      opkg)
        install_app_via_opkg "$selector"
        return 0
        ;;
      pica)
        install_pica_from_repo "$selector"
        return 0
        ;;
    esac
  fi

  opkg update >/dev/null 2>&1 || true
  if ! selector_is_structured "$selector" && opkg_has_package "$app"; then
    if [[ "$PICA_NON_INTERACTIVE" -eq 1 ]]; then
      if [[ "$PICA_FEED_POLICY" == "feed-first" || "$PICA_FEED_POLICY" == "feed-only" ]]; then
        install_app_via_opkg "$app"
        return 0
      fi
    elif prompt_yn "Found '$app' in opkg feeds. Install via opkg?" 1; then
      install_app_via_opkg "$app"
      return 0
    fi
  fi
  install_pica_from_repo "$selector"
}

install_pkgfile() {
  local pkgfile="$1"
  local selector="${2:-}"
  [[ -f "$pkgfile" ]] || die "pkgfile not found: $pkgfile"

  ensure_dirs

  log_info "Loading package files..."

  local tmpdir
  tmpdir="$(mktemp -d)"

  tar -xzf "$pkgfile" -C "$tmpdir"
  [[ -f "$tmpdir/manifest" ]] || die "package missing manifest"
  [[ -d "$tmpdir/cmd" ]] || die "package missing cmd/"
  [[ -d "$tmpdir/binary" ]] || die "package missing binary/"

  local manifest_json pkgname pica
  manifest_json="$(manifest_to_json "$tmpdir/manifest")"
  pkgname="$(manifest_get_first "$manifest_json" pkgname)"
  pica="$(manifest_get_first "$manifest_json" pica)"
  local pkgver_display
  pkgver_display="$(manifest_pkgver_display "$manifest_json")"
  local pkg_platform
  pkg_platform="$(manifest_get_first "$manifest_json" platform)"
  local pkg_arch
  pkg_arch="$(manifest_get_first "$manifest_json" arch)"
  local pkg_uname
  pkg_uname="$(manifest_get_first "$manifest_json" uname)"
  local pkg_luci
  pkg_luci="$(manifest_get_first "$manifest_json" luci)"
  local pkg_type
  pkg_type="$(manifest_get_first "$manifest_json" type)"

  local cmd_install cmd_update cmd_remove
  cmd_install="$(manifest_get_scalar "$manifest_json" cmd_install)"
  cmd_update="$(manifest_get_scalar "$manifest_json" cmd_update)"
  cmd_remove="$(manifest_get_scalar "$manifest_json" cmd_remove)"
  [[ -n "$pkgname" ]] || die "manifest missing pkgname"
  [[ -n "$(manifest_get_first "$manifest_json" pkgver)" ]] || die "manifest missing pkgver"
  [[ -n "$pkg_platform" ]] || die "manifest missing platform"
  [[ -n "$pkg_arch" ]] || die "manifest missing arch"

  local canonical_selector
  canonical_selector="$pkgname"
  local m_appname m_author m_version m_branch
  m_appname="$(manifest_get_first "$manifest_json" appname)"
  m_author="$(manifest_get_first "$manifest_json" author)"
  m_version="$(manifest_get_first "$manifest_json" version)"
  m_branch="$(manifest_get_first "$manifest_json" branch)"
  if [[ -n "$m_appname" ]]; then
    canonical_selector="$m_appname"
    if [[ -n "$m_author" ]]; then
      canonical_selector+="@$m_author"
    fi
    if [[ -n "$m_version" ]]; then
      canonical_selector+=":$m_version"
    fi
    if [[ -n "$m_branch" ]]; then
      canonical_selector+="($m_branch)"
    fi
  fi
  if [[ -z "$selector" ]]; then
    selector="$canonical_selector"
  fi

  local is_upgrade
  is_upgrade=0
  if jq -e --arg pkgname "$pkgname" '.installed[$pkgname] != null' "$PICA_DB_FILE" >/dev/null 2>&1; then
    is_upgrade=1
  fi

  # pica field is an optional minimum required pica-cli version.
  if [[ -n "$pica" ]]; then
    if ! ver_ge "$PICA_VERSION" "$pica"; then
      die "pica too old: pkg requires >= $pica, cli is $PICA_VERSION"
    fi
  fi

  # platform is informational (used for store/repo display), do not gate installs.
  local host_platform
  host_platform="$(detect_platform)"

  # 1) uname compatibility check first (portable baseline)
  local host_uname_raw host_uname
  host_uname_raw="$(uname -m)"
  host_uname="$(normalize_uname "$host_uname_raw")"
  local pkg_uname_norm
  pkg_uname_norm="$(normalize_uname "$pkg_uname")"
  if [[ -n "$pkg_uname" && "$pkg_uname_norm" != "$host_uname" ]]; then
    die "unsupported uname: pkg=$pkg_uname host=$host_uname_raw"
  fi

  # 2) arch match (pica-specific tag)
  # 2) arch match (OpenWrt/opkg arch). Recommended: use `all`.
  if [[ "$pkg_arch" != "all" ]]; then
    local host_arches
    host_arches="$(detect_opkg_arches || true)"
    if ! grep -qxF "$pkg_arch" <<<"$host_arches"; then
      die "unsupported arch: pkg=$pkg_arch (opkg arches: $(tr '\n' ' ' <<<"$host_arches" | sed -e 's/[[:space:]]\+/ /g' -e 's/[[:space:]]$//'))"
    fi
  fi

  # LuCI compatibility is only checked for packages declaring type=luci.
  # (type is repeatable; any matching 'luci' enables the check.)
  if manifest_has_type "$manifest_json" luci; then
    if [[ -n "$pkg_luci" ]]; then
      local host_luci
      host_luci="$(detect_luci_variant)"
      if [[ "$host_luci" == "unknown" ]]; then
        die "luci variant required ($pkg_luci) but cannot detect host"
      fi
      case "$pkg_luci" in
        lua1|js2) : ;;
        *) die "invalid luci value: $pkg_luci" ;;
      esac
      if [[ "$host_luci" != "$pkg_luci" ]]; then
        die "unsupported luci variant: pkg=$pkg_luci host=$host_luci"
      fi
    else
      die "type=luci requires luci=<lua1|js2>"
    fi
  fi

  log_info "Installing $pkgname..."
  log_info "  version: $pkgver_display"
  log_info "  platform: $pkg_platform (host: $host_platform)"
  log_info "  arch: $pkg_arch"
  if [[ -n "$pkg_uname" ]]; then
    log_info "  uname: $pkg_uname (host: $host_uname_raw)"
  fi
  if [[ -n "$pkg_type" ]]; then
    log_info "  type: $pkg_type"
  fi
  if [[ -n "$pkg_luci" ]]; then
    log_info "  luci: $pkg_luci"
  fi

  # Mark this as a pica-installed package for auto update selection.
  manifest_json="$(jq --arg source "pica" '.source //= $source' <<<"$manifest_json")"

  # Normalize optional selector metadata defaults.
  manifest_json="$(jq --arg fallback "$pkgname" '
    .appname //= ($fallback)
    | .author //= ""
    | .version //= ""
    | .branch //= ""
    | .protocol //= ""
  ' <<<"$manifest_json")"

  resolve_lang() {
    local lang=""
    lang="$(jq -r '.lang // empty' "$PICA_CONF_FILE" 2>/dev/null || true)"
    if [[ -z "$lang" ]]; then
      lang="zh-cn"
    fi
    echo "$lang"
  }

  expand_lang_template() {
    local template="$1"
    local lang="$2"
    echo "${template//\{lang\}/$lang}"
  }

  opkg update >/dev/null 2>&1 || true

  install_ipk_dir() {
    local label="$1"
    local dir="$2"
    [[ -d "$dir" ]] || return 0

    local ipk
    local installed_any=0
    shopt -s nullglob
    for ipk in "$dir"/*.ipk; do
      opkg_install_pkg "$label" "$ipk"
      installed_any=1
    done
    shopt -u nullglob
    if [[ "$installed_any" -eq 0 ]]; then
      die "no ipk files found in $label dir: $dir"
    fi
  }

  should_use_feeds() {
    local label="$1"
    local pkg_list="$2"
    local have_ipk_dir="$3"

    case "$PICA_FEED_POLICY" in
      feed-only)
        [[ -n "$pkg_list" ]] && echo 1 || echo -1
        return 0
        ;;
      packaged-only)
        echo 0
        return 0
        ;;
      feed-first)
        [[ -n "$pkg_list" ]] && echo 1 || echo 0
        return 0
        ;;
      packaged-first)
        [[ "$have_ipk_dir" -eq 1 ]] && echo 0 || echo 1
        return 0
        ;;
    esac

    if [[ "$have_ipk_dir" -eq 0 ]]; then
      echo 1
      return 0
    fi
    if [[ -z "$pkg_list" ]]; then
      echo 0
      return 0
    fi

    opkg update >/dev/null 2>&1 || true
    local total=0
    local available=0
    local dep
    while IFS= read -r dep; do
      [[ -z "$dep" ]] && continue
      total=$((total + 1))
      if opkg_has_package "$dep"; then
        available=$((available + 1))
      fi
    done <<<"$pkg_list"

    if [[ "$available" -eq 0 ]]; then
      echo 0
      return 0
    fi

    if prompt_yn "Found $available/$total $label packages in opkg feeds. Use feeds instead of packaged ipks?" 1; then
      echo 1
    else
      echo 0
    fi
  }

  install_via_feeds_or_ipk() {
    local label="$1"
    local pkg_list="$2"
    local ipk_dir="$3"
    local have_ipk_dir="$4"

    local use_feeds
    use_feeds="$(should_use_feeds "$label" "$pkg_list" "$have_ipk_dir")"
    if [[ "$use_feeds" -eq -1 ]]; then
      set_error_code E_POLICY_INVALID
      die "$label requires feed packages under feed-only policy"
    fi
    if [[ "$use_feeds" -eq 1 ]]; then
      [[ -n "$pkg_list" ]] || die "$label packages not defined in manifest"
      local dep
      while IFS= read -r dep; do
        [[ -z "$dep" ]] && continue
        opkg_install_pkg "$label" "$dep"
      done <<<"$pkg_list"
      return 0
    fi

    if [[ "$have_ipk_dir" -eq 1 ]]; then
      install_ipk_dir "$label" "$ipk_dir"
      return 0
    fi
    die "$label not available in feeds and no packaged ipks provided"
  }

  local app_list
  app_list="$(manifest_get_array "$manifest_json" app || true)"
  local lang
  lang="$(resolve_lang)"
  local i18n_template
  i18n_template="$(manifest_get_first "$manifest_json" app_i18n)"
  if [[ -n "$i18n_template" ]]; then
    app_list+=$'\n'
    app_list+="$(expand_lang_template "$i18n_template" "$lang")"
  fi

  reorder_app_list() {
    local list="$1"
    local core=""
    local luci=""
    local i18n=""
    local item
    while IFS= read -r item; do
      [[ -z "$item" ]] && continue
      case "$item" in
        luci-i18n-*) i18n+="$item"$'\n' ;;
        luci-app-*) luci+="$item"$'\n' ;;
        *) core+="$item"$'\n' ;;
      esac
    done <<<"$list"
    printf '%s%s%s' "$core" "$luci" "$i18n" | sed '/^$/d'
  }

  app_list="$(reorder_app_list "$app_list")"

  local precheck_json
  precheck_json="$(build_precheck_report "$manifest_json" "$tmpdir/depend" "$tmpdir/binary" "$app_list")"
  precheck_assert_no_missing "$precheck_json"

  local snap_before_tx snap_before_app snap_after_app snap_after_tx
  snap_before_tx="$(mktemp)"
  snap_before_app="$(mktemp)"
  snap_after_app="$(mktemp)"
  snap_after_tx="$(mktemp)"
  opkg_snapshot_installed "$snap_before_tx"

  # kmod: hard requirement. Must be installable.
  local kmod_list
  kmod_list="$(manifest_get_array "$manifest_json" kmod || true)"
  if [[ -n "$kmod_list" ]]; then
    local dep
    while IFS= read -r dep; do
      [[ -z "$dep" ]] && continue
      if ! opkg_is_installed "$dep"; then
        opkg_install_pkg "kmod" "$dep"
      fi
    done <<<"$kmod_list"
  fi

  # base: must be available via feeds or packaged depend/.
  local base_list
  base_list="$(manifest_get_array "$manifest_json" base || true)"
  local has_depend_dir=0
  [[ -d "$tmpdir/depend" ]] && has_depend_dir=1
  install_via_feeds_or_ipk "base" "$base_list" "$tmpdir/depend" "$has_depend_dir"

  opkg_snapshot_installed "$snap_before_app"

  # app: must be available via feeds or packaged binary/.
  install_via_feeds_or_ipk "app" "$app_list" "$tmpdir/binary" 1
  opkg_snapshot_installed "$snap_after_app"

  # lifecycle cmd scripts
  if [[ "$is_upgrade" -eq 1 ]]; then
    run_hook "$tmpdir" "$cmd_update" update
  else
    run_hook "$tmpdir" "$cmd_install" install
  fi

  # 3) install lifecycle cmd scripts (optional)
  # Cmd scripts must be available during remove/update even without the original pkgfile.
  mkdir -p "/usr/lib/pica/cmd/$pkgname"
  local hook_rel
  for hook_rel in "$cmd_install" "$cmd_update" "$cmd_remove"; do
    [[ -z "$hook_rel" ]] && continue
    if [[ "$hook_rel" == /* ]]; then
      continue
    fi
    if [[ -f "$tmpdir/$hook_rel" ]]; then
      mkdir -p "/usr/lib/pica/cmd/$pkgname/$(dirname "$hook_rel")"
      cp -f "$tmpdir/$hook_rel" "/usr/lib/pica/cmd/$pkgname/$hook_rel"
    else
      die "cmd script not found in package: $hook_rel"
    fi
  done

  # 4) install cmd/ payload to /usr/bin (optional)
  # Only when manifest declares at least one `cmd = ...` entry.
  if jq -e '.cmd? != null' <<<"$manifest_json" >/dev/null 2>&1; then
    if [[ -d "$tmpdir/cmd" ]]; then
      mkdir -p /usr/bin
      if command -v cp >/dev/null 2>&1; then
        cp -a "$tmpdir/cmd/." /usr/bin/
      else
        tar -C "$tmpdir/cmd" -cf - . | tar -C /usr/bin -xf -
      fi
    fi
  fi

  # 5) optional cmd/.env -> /etc/pica/env.d/<pkgname>.env
  if [[ -f "$tmpdir/cmd/.env" ]]; then
    mkdir -p /etc/pica/env.d
    cp -f "$tmpdir/cmd/.env" "/etc/pica/env.d/${pkgname}.env"
  fi

  opkg_snapshot_installed "$snap_after_tx"
  local tx_added_json app_added_json
  tx_added_json="$(pkg_list_diff_added "$snap_before_tx" "$snap_after_tx" | jq -R . | jq -s .)"
  app_added_json="$(pkg_list_diff_added "$snap_before_app" "$snap_after_app" | jq -R . | jq -s .)"

  report_set_install_result "$pkgname" "$selector" "$manifest_json" "$precheck_json" "$tx_added_json" "$app_added_json"

  db_set_installed "$pkgname" "$manifest_json" "$(readlink -f "$pkgfile" 2>/dev/null || echo "$pkgfile")"
  rm -rf "$tmpdir" "$snap_before_tx" "$snap_before_app" "$snap_after_app" "$snap_after_tx"
  log_info "Transaction completed"
}

install_pkg_source() {
  local source="$1"
  local selector="${2:-}"

  if [[ -f "$source" ]]; then
    install_pkgfile "$source" "$selector"
    return 0
  fi

  if is_supported_pkg_url "$source"; then
    ensure_dirs
    need_cmd tar
    mkdir -p "$PICA_CACHE_DIR/pkgs"

    local guessed cached
    guessed="$(basename "$source")"
    guessed="$(sanitize_cache_filename "$guessed")"
    cached="$PICA_CACHE_DIR/pkgs/$guessed"

    log_info "Downloading pkg from URL: $source"
    fetch_url "$source" >"$cached.tmp" || die "download failed: $source"
    mv "$cached.tmp" "$cached"
    install_pkgfile "$cached" "$selector"
    return 0
  fi

  die "pkg source not found or unsupported URL: $source"
}

remove_pkg() {
  local pkgname="$1"
  ensure_dirs

  local manifest_json
  manifest_json="$(jq -c --arg pkgname "$pkgname" '.installed[$pkgname].manifest // empty' "$PICA_DB_FILE")"
  [[ -n "$manifest_json" ]] || die "not installed: $pkgname"

  local cmd_remove
  cmd_remove="$(manifest_get_scalar "$manifest_json" cmd_remove)"

  log_info "Removing $pkgname..."

  run_cmd_install_tree "$pkgname/$cmd_remove" remove

  # remove cmd files if listed, else do nothing (avoid deleting unknown files)
  # We support optional 'cmd' entries in manifest listing relative filenames.
  while IFS= read -r cmdpath; do
    [[ -z "$cmdpath" ]] && continue
    log_info "removing file: /usr/bin/$cmdpath"
    rm -f "/usr/bin/$cmdpath" || true
  done < <(manifest_get_array "$manifest_json" cmd || true)

  # remove opkg packages if listed explicitly (optional)
  while IFS= read -r opkg_name; do
    [[ -z "$opkg_name" ]] && continue
    log_info "removing opkg package: $opkg_name"
    if ! out="$(opkg remove "$opkg_name" 2>&1)"; then
      set_error_code E_OPKG_REMOVE
      die "opkg remove failed: $opkg_name detail=[$out]"
    fi
  done < <(manifest_get_array "$manifest_json" opkg || true)

  if [[ -f "/etc/pica/env.d/${pkgname}.env" ]]; then
    log_info "removing env: /etc/pica/env.d/${pkgname}.env"
    rm -f "/etc/pica/env.d/${pkgname}.env" || true
  fi

  db_del_installed "$pkgname"
  log_info "Transaction completed"
}

query_installed() {
  ensure_dirs
  jq -r '
    .installed
    | to_entries
    | sort_by(.key)
    | .[]
    | "\(.key)\t\(.value.manifest.pkgver // \"\")\(if (.value.manifest.pkgrel // \"\")|length>0 then \"-\" + (.value.manifest.pkgrel // \"\") else \"\" end)\t\(.value.manifest.platform // \"\")"
  ' "$PICA_DB_FILE"
}

query_info() {
  local pkgname="$1"
  ensure_dirs

  local entry
  entry="$(jq -c --arg pkgname "$pkgname" '.installed[$pkgname] // empty' "$PICA_DB_FILE")"
  [[ -n "$entry" ]] || die "not installed: $pkgname"

  local manifest
  manifest="$(jq -c '.manifest' <<<"$entry")"

  echo "Name            : $pkgname"
  echo "Version         : $(manifest_pkgver_display "$manifest")"
  echo "Pkgver          : $(manifest_get_first "$manifest" pkgver)"
  echo "Pkgrel          : $(manifest_get_first "$manifest" pkgrel)"
  echo "AppName         : $(manifest_get_first "$manifest" appname)"
  echo "Author          : $(manifest_get_first "$manifest" author)"
  echo "Version Tag     : $(manifest_get_first "$manifest" version)"
  echo "Branch          : $(manifest_get_first "$manifest" branch)"
  echo "Protocol        : $(manifest_get_first "$manifest" protocol)"
  echo "Platform        : $(manifest_get_first "$manifest" platform)"
  echo "Arch            : $(manifest_get_first "$manifest" arch)"
  echo "Uname           : $(manifest_get_first "$manifest" uname)"
  echo "Type            : $(manifest_get_first "$manifest" type)"
  echo "License         : $(manifest_get_first "$manifest" license)"
  echo "Proprietary     : $(manifest_get_first "$manifest" proprietary)"
}

query_license() {
  local pkgname="$1"
  ensure_dirs

  local manifest
  manifest="$(jq -c --arg pkgname "$pkgname" '.installed[$pkgname].manifest // empty' "$PICA_DB_FILE")"
  [[ -n "$manifest" ]] || die "not installed: $pkgname"

  local license proprietary
  license="$(manifest_get_first "$manifest" license)"
  proprietary="$(manifest_get_first "$manifest" proprietary)"

  if [[ -n "$license" ]]; then
    echo "$license"
  fi
  if [[ -n "$proprietary" ]]; then
    echo "proprietary=$proprietary"
  fi
}

upgrade_all() {
  ensure_dirs
  [[ -f "$PICA_INDEX_FILE" ]] || die "missing index: run 'pica -S' first"

  local list
  list="$(jq -r '
    .installed
    | to_entries
    | sort_by(.key)
    | .[]
    | select((.value.manifest.source // "") == "pica")
    | [
        .key,
        (.value.manifest.appname // .value.manifest.pkgname // .key),
        (.value.manifest.author // ""),
        (.value.manifest.version // ""),
        (.value.manifest.branch // ""),
        (
          (.value.manifest.pkgver // "")
          +
          (if (.value.manifest.pkgrel // "") | length > 0 then "-" + (.value.manifest.pkgrel // "") else "" end)
        )
      ]
      | @tsv
  ' "$PICA_DB_FILE")"

  if [[ -z "$list" ]]; then
    log_info "No pica packages to upgrade"
    return 0
  fi

  local updated_any=0
  local line pkgname appname author version branch installed_ver selector
  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    pkgname="$(cut -f1 <<<"$line")"
    appname="$(cut -f2 <<<"$line")"
    author="$(cut -f3 <<<"$line")"
    version="$(cut -f4 <<<"$line")"
    branch="$(cut -f5 <<<"$line")"
    installed_ver="$(cut -f6 <<<"$line")"

    selector="$appname"
    if [[ -n "$author" ]]; then
      selector+="@$author"
    fi
    if [[ -n "$version" ]]; then
      selector+=":$version"
    fi
    if [[ -n "$branch" ]]; then
      selector+="($branch)"
    fi

    local candidate best best_ver
    best_ver=""
    best=""
    while IFS= read -r candidate; do
      [[ -z "$candidate" ]] && continue
      local v
      v="${candidate%%$'\t'*}"
      if pkgver_ge "$v" "$best_ver"; then
        best_ver="$v"
        best="$candidate"
      fi
    done < <(find_pica_package_in_index "$selector" || true)

    if [[ -z "$best" ]]; then
      log_warn "Skip $pkgname: not found in index"
      continue
    fi

    if pkgver_ge "$installed_ver" "$best_ver"; then
      log_info "Up to date: $pkgname ($installed_ver)"
      continue
    fi

    log_info "Upgrading $pkgname: $installed_ver -> $best_ver"
    install_pica_from_repo "$selector"
    updated_any=1
  done <<<"$list"

  if [[ "$updated_any" -eq 0 ]]; then
    log_info "All packages are up to date"
  fi
}

main() {
  local -a args
  args=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --json)
        PICA_JSON_MODE="all"
        shift
        ;;
      --json-errors)
        PICA_JSON_MODE="errors"
        shift
        ;;
      --non-interactive)
        PICA_NON_INTERACTIVE=1
        shift
        ;;
      --feed-policy)
        [[ $# -ge 2 ]] || die "--feed-policy requires <mode>"
        PICA_FEED_POLICY="$2"
        shift 2
        ;;
      *)
        args+=("$1")
        shift
        ;;
    esac
  done

  set -- "${args[@]}"

  case "$PICA_FEED_POLICY" in
    ask|feed-first|packaged-first|feed-only|packaged-only) : ;;
    *)
      set_error_code E_POLICY_INVALID
      die "invalid --feed-policy: $PICA_FEED_POLICY"
      ;;
  esac

  if [[ "$PICA_JSON_MODE" != "none" ]] && ! command -v jq >/dev/null 2>&1; then
    set_error_code E_MISSING_COMMAND
    die "--json/--json-errors requires command: jq"
  fi

  if [[ $# -ge 1 ]]; then
    case "$1" in
      -h|--help|help)
        usage
        json_emit_success "$1" "usage"
        return 0
        ;;
      --version)
        echo "$PICA_VERSION"
        json_emit_success "--version" "$PICA_VERSION"
        return 0
        ;;
    esac
  fi

  need_cmd jq
  need_any_cmd uclient-fetch wget curl
  acquire_lock
  trap release_lock EXIT

  if [[ $# -eq 0 ]]; then
    usage
    exit 2
  fi

  case "$1" in
    --version)
      json_set_phase version
      echo "$PICA_VERSION"
      json_emit_success "--version" "$PICA_VERSION"
      ;;
    -S)
      json_set_phase sync
      sync_repos
      json_emit_success "-S" "repos"
      ;;
    -Su)
      json_set_phase upgrade
      need_cmd opkg
      upgrade_all
      json_emit_success "-Su" "all"
      ;;
    -Syu)
      json_set_phase sync
      need_cmd opkg
      sync_repos
      json_set_phase upgrade
      upgrade_all
      json_emit_success "-Syu" "all"
      ;;
    -Si)
      json_set_phase install
      need_cmd opkg
      [[ $# -ge 2 ]] || die "-Si requires <selector>"
      install_app_auto "$2"
      json_emit_success "-Si" "$2"
      ;;
    -So)
      json_set_phase install
      need_cmd opkg
      [[ $# -ge 2 ]] || die "-So requires <selector>"
      install_app_via_opkg "$2"
      json_emit_success "-So" "$2"
      ;;
    -Sp)
      json_set_phase install
      need_cmd opkg
      [[ $# -ge 2 ]] || die "-Sp requires <selector>"
      install_pica_from_repo "$2"
      json_emit_success "-Sp" "$2"
      ;;
    -U)
      json_set_phase install
      need_cmd opkg
      need_cmd tar
      [[ $# -ge 2 ]] || die "-U requires <pkgfile|url>"
      install_pkg_source "$2"
      json_emit_success "-U" "$2"
      ;;
    -R)
      json_set_phase remove
      need_cmd opkg
      [[ $# -ge 2 ]] || die "-R requires <pkgname>"
      remove_pkg "$2"
      json_emit_success "-R" "$2"
      ;;
    -Q)
      json_set_phase query
      query_installed
      json_emit_success "-Q" "installed"
      ;;
    -Qi)
      json_set_phase query
      [[ $# -ge 2 ]] || die "-Qi requires <pkgname>"
      query_info "$2"
      json_emit_success "-Qi" "$2"
      ;;
    -Ql)
      json_set_phase query
      [[ $# -ge 2 ]] || die "-Ql requires <pkgname>"
      query_license "$2"
      json_emit_success "-Ql" "$2"
      ;;
    -h|--help|help)
      usage
      ;;
    *)
      die "unknown arg: $1"
      ;;
  esac
}

main "$@"

exit 0
